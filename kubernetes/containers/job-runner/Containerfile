# Image that geo-datasets flow runs execute in.
#
# Build from the repository root, so that the lockfile and the data_manager
# source are in the build context:
#
#   podman build -f kubernetes/containers/job-runner/Containerfile \
#       -t ghcr.io/aiddata/geodata-container:$(git rev-parse --short HEAD) .

FROM docker.io/prefecthq/prefect:3.7.4-python3.11

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gdal-bin \
    libgdal-dev \
    openssh-client \
    git \
    wget \
&& rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.9.5 /uv /usr/local/bin/uv

# Dependencies come from the lockfile rather than a hand-maintained
# requirements.txt, so this image cannot drift from what the datasets resolve
# against locally.
WORKDIR /opt/geo-datasets
COPY pyproject.toml uv.lock ./
COPY data_manager/ data_manager/
RUN uv export --frozen --no-editable --no-emit-project -o /tmp/requirements.txt \
 && uv pip install --system --no-cache -r /tmp/requirements.txt \
 && rm /tmp/requirements.txt

# Flow pods run as the SciClone user (set by the work pool base job template),
# not as a user baked into this image, so anything written at runtime has to
# live somewhere world-writable rather than in a fixed home directory.
ENV HOME=/tmp \
    PREFECT_HOME=/tmp/.prefect \
    PYTHONUSERBASE=/tmp/python-user \
    PATH=/tmp/python-user/bin:$PATH

COPY kubernetes/containers/job-runner/prepare.sh /usr/bin/prepare.sh
ENTRYPOINT ["/usr/bin/prepare.sh"]
